generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PARENT
  TEACHER
  ADMIN
}

enum TeacherApplicationStatus {
  DRAFT
  SUBMITTED
  INTERVIEW
  APPROVED
  REJECTED
}

enum Modality {
  DOMICILE
  VISIO
  MIXTE
}

enum RequestStatus {
  NEW
  MATCHED
  CLOSED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?
  requests       TutoringRequest[] @relation("ParentRequests")
}

model TeacherProfile {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  fullName        String?
  phone           String?
  city            String?
  bio             String?
  experienceYears Int?
  diploma         String?

  status    TeacherApplicationStatus @default(DRAFT)

  subjects  String[]
  levels    String[]
  cities    String[]

  cvFileName             String?
  cvMimeType             String?
  cvSize                 Int?
  cvData                 Bytes?
  cvReceivedAt           DateTime?
  applicationEmailSentAt DateTime?

  listings  TutorListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentProfile {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  fullName  String?
  phone     String?
  city      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TutorListing {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])

  title       String
  subject     String
  levels      String[]
  city        String
  modality    Modality
  description String?
  rateMin     Int?
  rateMax     Int?
  isActive    Boolean  @default(true)

  // relations demandes
  sourceRequests   TutoringRequest[] @relation("SourceListing")
  assignedRequests TutoringRequest[] @relation("AssignedListing")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TutoringRequest {
  id           String   @id @default(cuid())
  parentId     String
  parent       User     @relation("ParentRequests", fields: [parentId], references: [id])

  subject          String
  level            String
  city             String
  modality         Modality
  studentName      String?
  contactPhone     String?
  preferredContact String?
  goals            String?
  availability     String?

  status       RequestStatus @default(NEW)

  // Offre d’origine (celle cliquée)
  sourceListingId String?
  sourceListing   TutorListing? @relation("SourceListing", fields: [sourceListingId], references: [id])

  // Offre assignée par admin (matching)
  assignedListingId String?
  assignedListing   TutorListing? @relation("AssignedListing", fields: [assignedListingId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
